# Devin API credentials
DEVIN_API_KEY=cog_your_service_user_key_here
DEVIN_ORG_ID=org-your_org_id_here

# Target repository (GitHub owner/repo)
TARGET_REPO=razasekha/superset-devin

# APScheduler cron for Agent 2 scan (default: hourly)
SCAN_CRON=0 * * * *

# ACU limits per agent role (0 = no limit)
MAX_ACU_INJECTOR=10
MAX_ACU_SCANNER=15
MAX_ACU_FIXER=20

# Poll settings
POLL_INTERVAL_SECONDS=15
POLL_TIMEOUT_SECONDS=3600

# GitHub token for opening issues (needs repo scope on the fork)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=razasekha/superset-devin
